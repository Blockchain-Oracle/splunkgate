<?xml version="1.0" encoding="UTF-8"?>
<!--
  SplunkGate — Regulator Evidence Pack (SUIT rebuild, story-suit-evidence-pack).

  Replaces the Dashboard Studio v2 JSON-in-XML implementation with a custom
  React/SUIT bundle so we control the visual treatment end-to-end. The
  Dossier design system + the verbatim SR 26-2 footnote 3 panel + the NIST
  RMF + EU AI Act + HIPAA/PCI tables all live inside the JS bundle now.

  SPL data sources are unchanged (lifted verbatim from the archived
  Dashboard Studio v2 definition at docs/archive/dashboard-studio-v2/).
  The bundle uses splunkjs.mvc.SearchManager to run them at view-load time
  and on input changes.

  Rollback: docs/archive/dashboard-studio-v2/regulator_evidence_pack.xml.
-->
<view template="dashboards/template.dashboard.html"
      stylesheet="splunkgate-suit/tokens.css,splunkgate-suit/evidence_pack.css"
      script="splunkgate-suit/evidence_pack.js">
    <label>SplunkGate — Regulator Evidence Pack</label>
    <description>Examiner-grade audit artifact: NIST AI RMF function mapping, SR 26-2 scope quote, EU AI Act Article 6 mapping, profile-gated HIPAA / PCI panels, browser-print PDF export. Custom React/SUIT view; SPL queries unchanged from the archived Dashboard Studio v2 definition.</description>
    <module name="HTML">
        <param name="html"><![CDATA[
            <div id="splunkgate-evidence-pack"></div>
        ]]></param>
    </module>
</view>
