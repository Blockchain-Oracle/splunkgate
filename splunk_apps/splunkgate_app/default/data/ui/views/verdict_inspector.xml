<?xml version="1.0" encoding="UTF-8"?>
<!--
  SplunkGate — Verdict Inspector (SUIT rebuild, story-suit-verdict-inspector).

  D3 "microscope" per docs/dashboard design brief: two-column layout with
  filter bar (4 inputs) + verdict list table (left, 60%) / detail panel +
  related events (right, 40%). Drill-down to ES investigation workbench
  on detail-panel click. The trace_id copy-to-clipboard chip is the hero
  micro-interaction.

  SPL data sources unchanged (lifted verbatim from
  docs/archive/dashboard-studio-v2/verdict_inspector.xml).

  Rollback: docs/archive/dashboard-studio-v2/verdict_inspector.xml.
-->
<view template="dashboards/template.dashboard.html"
      stylesheet="splunkgate-suit/tokens.css,splunkgate-suit/verdict_inspector.css"
      script="splunkgate-suit/verdict_inspector.js">
    <label>SplunkGate — Verdict Inspector</label>
    <description>SOC + AI platform engineer drill-down. Filter by time / agent / rule / severity / verdict label, click a row to inspect a verdict and see related events from the same trace_id across all four surfaces. Dossier-styled SUIT view; SPL queries unchanged from the archived Dashboard Studio v2 definition.</description>
    <module name="HTML">
        <param name="html"><![CDATA[
            <div id="splunkgate-verdict-inspector"></div>
        ]]></param>
    </module>
</view>
